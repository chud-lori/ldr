MONGO_URI=mongodb://localhost:27017
PORT=8080
MONGO_DB=test

# On-disk root for Film Roll uploads (photos + short video).
# Dev: leave at default to write under ./media in your working dir.
# Prod: set to a system-managed path that survives redeploys, e.g.
#   MEDIA_ROOT=/var/lib/ldr/media
# See deployment.md §6a for the host setup commands (mkdir + chown + chmod).
MEDIA_ROOT=./media
